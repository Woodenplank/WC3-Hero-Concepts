Guard deflect
    Events
        Game - PreDamageEvent becomes Equal to 1.00
    Conditions
        (DamageEventTarget is in Guard_ug.) Equal to True
    Actions
        Set VariableSet Guard_attacker = DamageEventSource
        Set VariableSet Guard_attacked = DamageEventTarget
        Set VariableSet Guard_lvl = ((Level of Swordsaint: Guard  for Guard_attacked) - 1)
        Custom script:   set udg_Guard_chance = GetAbilityReal("aoe",udg_Guard_attacked, udg_Guard_lvl, 'A001')
        If (All Conditions are True) then do (Then Actions) else do (Else Actions)
            If - Conditions
                (Random real number between 0.00 and 1.00) Less than or equal to Guard_chance
            Then - Actions
                -------- Deflect or Riposte --------
                If (All Conditions are True) then do (Then Actions) else do (Else Actions)
                    If - Conditions
                        IsDamageMelee Equal to True
                    Then - Actions
                        -------- Melee :: reflect 50% of damage --------
                        Set VariableSet NextDamageType = DamageEventAttackT
                        Unit - Cause Guard_attacked to damage Guard_attacker, dealing (DamageEventPrevAmt x 0.50) damage of attack type Spells and damage type Normal
                        Set VariableSet DamageEventAmount = (DamageEventAmount x 0.50)
                        Special Effect - Create a special effect attached to the chest of Guard_attacked using Abilities\Spells\Human\Defend\DefendCaster.mdl
                        Special Effect - Destroy (Last created special effect)
                    Else - Actions
                        If (All Conditions are True) then do (Then Actions) else do (Else Actions)
                            If - Conditions
                                IsDamageRanged Equal to True
                            Then - Actions
                                -------- Ranged :: reduce damage only --------
                                Set VariableSet DamageEventAmount = (DamageEventAmount x 0.10)
                                Special Effect - Create a special effect attached to the chest of Guard_attacked using Abilities\Spells\Human\Defend\DefendCaster.mdl
                                Special Effect - Destroy (Last created special effect)
                            Else - Actions
                                -------- Else :: non-standard attack --------
            Else - Actions
                -------- chance roll failed --------
